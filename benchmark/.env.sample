# Benchmark configuration. Copy to .env and edit; .env is git-ignored.

# --- woodpecker (points at the ecommerce-demo cluster) ---
WP_GRAPH_BACKEND=falkordb
WP_FALKOR_HOST=localhost
WP_FALKOR_PORT=6379
WP_FALKOR_GRAPH=ecommerce
WP_TOPOLOGY=k8s
WP_K8S_NAMESPACE=ecommerce
WP_K8S_CONTEXT=kind-ecommerce
WP_METRICS_BACKEND=prometheus
WP_PROM_URL=http://localhost:19090
# Services expected to be scraped - a monitored service with no live target is a
# blind spot. Lists every app service so the blind-spot scenarios have targets.
WP_MONITORED_SERVICES=gateway,web,mobilebff,catalog,cart,orders,users,recommendations,payments,inventory,shipping,notifications,ledger,email

# --- LLM for the HolmesGPT arm (only needed for the Holmes comparison) ---
# litellm native DeepSeek provider; supply your own key.
DEEPSEEK_API_KEY=
